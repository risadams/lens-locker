{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LensLocker",
  "version": "0.1.0",
  "identifier": "com.lenslocker.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "create": false,
        "title": "LensLocker",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "models/onnxruntime.dll": "models/onnxruntime.dll",
      "models/face_detection_yunet/*": "models/face_detection_yunet/",
      "models/face_recognition_sface/*": "models/face_recognition_sface/",
      "models/siglip-so400m-onnx/model.onnx": "models/siglip-so400m-onnx/model.onnx",
      "models/siglip-so400m-onnx/config.json": "models/siglip-so400m-onnx/config.json",
      "models/siglip-so400m-onnx/tokenizer.json": "models/siglip-so400m-onnx/tokenizer.json",
      "models/siglip-so400m-onnx/spiece.model": "models/siglip-so400m-onnx/spiece.model",
      "../LICENSES.txt": "LICENSES.txt"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  }
}
